 * Initialize database and listen on provided port
 */

async function startServer() {
  try {
    console.log('\n========== DATABASE INITIALIZATION ==========\n');
    
    // Initialize database schema and seed data
    const initSuccess = await db.initialize();
    
    if (!initSuccess) {
      console.error('\n✗ Failed to initialize database. Some features may not work.\n');
      console.error('Please check your MySQL connection and try again.\n');
    }
    
    console.log('========== STARTING SERVER ==========\n');
    
    // Listen on provided port, on all network interfaces.
    server.listen(port);
    server.on('error', onError);
    server.on('listening', onListening);
  } catch (error) {
    console.error('Fatal error during startup:', error);
    process.exit(1);
  }
}
